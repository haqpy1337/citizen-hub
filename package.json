{
  "name": "citizen-hub",
  "version": "1.0.0",
  "private": true,
  "description": "Star Citizen companion app — live UEX data, refinery jobs, trade routes.",
  "author": "haqpy",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate",
    "electron:compile": "tsc --project electron/tsconfig.json",
    "electron:dev": "npm run build && npm run electron:compile && electron .",
    "electron:build": "npm run build && npm run electron:compile && electron-builder --win",
    "electron:publish": "npm run build && npm run electron:compile && electron-builder --win --publish always"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "animejs": "^3.2.2",
    "bcryptjs": "^2.4.3",
    "electron-updater": "^6.8.9",
    "jose": "^5.9.6",
    "next": "14.2.15",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.35.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/animejs": "^3.1.13",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.16.11",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@types/sharp": "^0.31.1",
    "autoprefixer": "^10.4.20",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.47",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.3"
  }
}
