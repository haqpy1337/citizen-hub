{
  "name": "citizen-hub",
  "version": "2.3.68",
  "private": true,
  "description": "Star Citizen companion app — live UEX data, refinery jobs, trade routes.",
  "author": "haqpy",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev:renderer": "vite",
    "dev": "concurrently -k \"npm run dev:renderer\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build && tsc --project electron/tsconfig.json",
    "electron:build": "npm run build && electron-builder --win",
    "electron:publish": "npm run build && electron-builder --win --publish always",
    "generate-icon": "node scripts/generate-icon.mjs"
  },
  "dependencies": {
    "animejs": "^3.2.2",
    "electron-updater": "^6.8.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sql.js": "^1.12.0"
  },
  "devDependencies": {
    "@types/animejs": "^3.1.13",
    "@types/node": "^20.16.11",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@types/sql.js": "^1.4.9",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "png-to-ico": "^3.0.2",
    "postcss": "^8.4.47",
    "sharp": "^0.35.2",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.3",
    "vite": "^5.4.8",
    "wait-on": "^8.0.1"
  }
}
