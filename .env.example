# --- Datenbank -------------------------------------------------------------
# SQLite (Standard, kein Setup noetig). Fuer PostgreSQL: in prisma/schema.prisma
# provider auf "postgresql" stellen und hier die Verbindungs-URL eintragen.
DATABASE_URL="file:./dev.db"

# --- Session / Auth --------------------------------------------------------
# Langer Zufallsstring. Generieren z.B. mit:  openssl rand -base64 48
AUTH_SECRET="bitte-aendern-langer-zufallsstring"

# --- UEX Corp API (Live-Daten) --------------------------------------------
# API-Key kostenlos anfordern unter: https://uexcorp.space/api/apps
# Ohne Key funktionieren manche Endpunkte eingeschraenkt; mit Key vollstaendig.
UEX_API_BASE="https://api.uexcorp.space/2.0"
UEX_API_TOKEN=""
